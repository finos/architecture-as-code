function buildEarth() {
    const group = new THREE.Group();

    // Full underground cross-section (front face of earth)
    const earthGeo = new THREE.PlaneGeometry(200, 200);
    const earthMat = new THREE.ShaderMaterial({
        uniforms: {
            topColor: { value: new THREE.Color(COLORS.dirtLight) },
            midColor: { value: new THREE.Color(COLORS.dirtMid) },
            bottomColor: { value: new THREE.Color(COLORS.dirtDark) },
        },
        vertexShader: `
            varying vec2 vUv;
            void main() {
                vUv = uv;
                gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
            }
        `,
        fragmentShader: `
            uniform vec3 topColor;
            uniform vec3 midColor;
            uniform vec3 bottomColor;
            varying vec2 vUv;
            void main() {
                float t = vUv.y;
                vec3 color = t > 0.5
                    ? mix(midColor, topColor, (t - 0.5) * 2.0)
                    : mix(bottomColor, midColor, t * 2.0);
                // Add noise-like variation for earthiness
                float grain = fract(sin(dot(vUv * 400.0, vec2(12.9898, 78.233))) * 43758.5453);
                color = mix(color, color * 0.85, grain * 0.15);
                gl_FragColor = vec4(color, 1.0);
            }
        `,
        side: THREE.FrontSide,
    });
    const earth = new THREE.Mesh(earthGeo, earthMat);
    earth.position.set(0, -30, 0);
    group.add(earth);

    // Back wall of earth
    const backGeo = new THREE.PlaneGeometry(200, 200);
    const backMat = new THREE.MeshLambertMaterial({ color: COLORS.dirtDark });
    const backWall = new THREE.Mesh(backGeo, backMat);
    backWall.position.set(0, -30, -CHAMBER_DEPTH);
    group.add(backWall);

    return group;
}

// ── Layout Helpers ──────────────────────────────────────────────────
// Barycenter: average slot index of a node's neighbors (for crossing reduction)
function barycenter(nodeId, neighbors, orderInLayer) {
    const nbrs = neighbors[nodeId];
    if (!nbrs || nbrs.size === 0) return orderInLayer[nodeId] || 0;
    let sum = 0, count = 0;
    nbrs.forEach(nbrId => {
        if (orderInLayer[nbrId] !== undefined) {
            sum += orderInLayer[nbrId];
            count++;
        }
    });
    return count > 0 ? sum / count : (orderInLayer[nodeId] || 0);
}

// ── Layout Engine ───────────────────────────────────────────────────
function computeLayout(nodes, relationships) {
    const positions = {};
    const nodeMap = {};
    nodes.forEach(n => nodeMap[n['unique-id']] = n);

    // Build adjacency from connects & interacts (directional: top → bottom)
    const children = {};  // parent → [child]
    const parents = {};   // child → [parent]
    const allIds = new Set(nodes.map(n => n['unique-id']));
    nodes.forEach(n => { children[n['unique-id']] = []; parents[n['unique-id']] = []; });

    // Build containment map: container → [contained nodes]
    const containment = {};
    const containedBy = {}; // nodeId → containerId
    relationships.forEach(rel => {
        const rt = rel['relationship-type'];
        if (rt['composed-of']) {
            containment[rt['composed-of'].container] = rt['composed-of'].nodes;
            rt['composed-of'].nodes.forEach(id => { containedBy[id] = rt['composed-of'].container; });
        }
        if (rt['deployed-in']) {
            containment[rt['deployed-in'].container] = rt['deployed-in'].nodes;
            rt['deployed-in'].nodes.forEach(id => { containedBy[id] = rt['deployed-in'].container; });
        }
    });

    // Build directional edges for layering
    relationships.forEach(rel => {
        const rt = rel['relationship-type'];
        if (rt.connects) {
            const src = rt.connects.source.node;
            const dst = rt.connects.destination.node;
            if (allIds.has(src) && allIds.has(dst)) {
                children[src].push(dst);
                parents[dst].push(src);
            }
        }
        if (rt.interacts) {
            const actor = rt.interacts.actor;
            (rt.interacts.nodes || []).forEach(targetId => {
                if (allIds.has(actor) && allIds.has(targetId)) {
                    children[actor].push(targetId);
                    parents[targetId].push(actor);
                }
            });
        }
    });

    // Assign layers via topological BFS (longest path = deepest layer)
    const layers = {};
    const surfaceTypes = new Set(['actor', 'webclient']);

    // Find roots: nodes with no parents, or surface types
    const roots = nodes.filter(n => 
        parents[n['unique-id']].length === 0 || surfaceTypes.has(n['node-type'])
    ).map(n => n['unique-id']);

    // BFS assign layers (deeper = further from roots)
    const queue = roots.map(id => ({ id, layer: 0 }));
    const visited = new Set();
    // Initialize all surface types as layer 0
    roots.forEach(id => { layers[id] = 0; });

    while (queue.length > 0) {
        const { id, layer } = queue.shift();
        if (visited.has(id) && layers[id] >= layer) continue;
        visited.add(id);
        layers[id] = Math.max(layers[id] || 0, layer);
        children[id].forEach(childId => {
            const nextLayer = layer + 1;
            if (!layers[childId] || layers[childId] < nextLayer) {
                layers[childId] = nextLayer;
                queue.push({ id: childId, layer: nextLayer });
            }
        });
    }

    // Assign layer to any unvisited nodes
    nodes.forEach(n => {
        if (layers[n['unique-id']] === undefined) {
            layers[n['unique-id']] = 1;
        }
    });

    // Skip container nodes that contain other nodes (they'll be drawn as outlines)
    const containerIds = new Set(Object.keys(containment));

    // Build undirected neighbor map for barycentric ordering
    const neighbors = {};
    nodes.forEach(n => { neighbors[n['unique-id']] = new Set(); });
    relationships.forEach(rel => {
        const rt = rel['relationship-type'];
        if (rt.connects) {
            const s = rt.connects.source.node, d = rt.connects.destination.node;
            if (allIds.has(s) && allIds.has(d)) { neighbors[s].add(d); neighbors[d].add(s); }
        }
        if (rt.interacts) {
            const a = rt.interacts.actor;
            (rt.interacts.nodes || []).forEach(t => {
                if (allIds.has(a) && allIds.has(t)) { neighbors[a].add(t); neighbors[t].add(a); }
            });
        }
    });

    // Group non-container nodes by layer
    const layerGroups = {};
    nodes.forEach(n => {
        const id = n['unique-id'];
        if (containerIds.has(id)) return;
        const layer = layers[id];
        if (!layerGroups[layer]) layerGroups[layer] = [];
        layerGroups[layer].push(id);
    });

    const sortedLayers = Object.keys(layerGroups).map(Number).sort((a, b) => a - b);

    // Initial ordering: assign each node a slot index within its layer
    const orderInLayer = {}; // nodeId → position index
    sortedLayers.forEach(layer => {
        layerGroups[layer].forEach((id, i) => { orderInLayer[id] = i; });
    });

    // Barycentric ordering: iteratively reorder each layer to minimize crossings.
    // For each node, compute its barycenter = average slot index of its neighbors
    // in adjacent layers, then sort the layer by that value.
    for (let pass = 0; pass < 8; pass++) {
        // Forward pass (top → bottom)
        sortedLayers.forEach(layer => {
            const group = layerGroups[layer];
            group.sort((a, b) => {
                const baryA = barycenter(a, neighbors, orderInLayer);
                const baryB = barycenter(b, neighbors, orderInLayer);
                return baryA - baryB;
            });
            group.forEach((id, i) => { orderInLayer[id] = i; });
        });
        // Reverse pass (bottom → top)
        for (let i = sortedLayers.length - 1; i >= 0; i--) {
            const group = layerGroups[sortedLayers[i]];
            group.sort((a, b) => {
                const baryA = barycenter(a, neighbors, orderInLayer);
                const baryB = barycenter(b, neighbors, orderInLayer);
                return baryA - baryB;
            });
            group.forEach((id, idx) => { orderInLayer[id] = idx; });
        }
    }

    // Position each layer as a row using the optimized ordering
    sortedLayers.forEach((layer, layerIdx) => {
        const group = layerGroups[layer];
        const y = layer === 0 ? -1.5 : -(layerIdx) * GRID_SPACING_Y - 3;
        group.forEach((id, col) => {
            const x = (col - (group.length - 1) / 2) * GRID_SPACING_X;
            positions[id] = new THREE.Vector3(x, y, 0);
        });
    });

    // Position container nodes: center them around their children
    containerIds.forEach(containerId => {
        const childIds = containment[containerId].filter(id => positions[id]);
        if (childIds.length > 0) {
            const center = new THREE.Vector3();
            childIds.forEach(id => center.add(positions[id]));
            center.divideScalar(childIds.length);
            positions[containerId] = center.clone();
        } else {
            const existingPositions = Object.values(positions);
            const minY = existingPositions.length > 0 
                ? Math.min(...existingPositions.map(p => p.y)) : -5;
            positions[containerId] = new THREE.Vector3(0, minY - GRID_SPACING_Y, 0);
        }
    });

    return { positions, containment };
}

// ── Chamber Builder ─────────────────────────────────────────────────
function createChamber(node, position, scale = 1) {
    const group = new THREE.Group();
    const nodeType = node['node-type'] || 'system';
    const color = COLORS.nodeTypes[nodeType] || COLORS.chamber;
    const cw = CHAMBER_WIDTH * scale;
    const ch = CHAMBER_HEIGHT * scale;
    const cd = CHAMBER_DEPTH * scale;

    // Rounded cave shape using a beveled box
    let chamberGeo;
    if (nodeType === 'database') {
        chamberGeo = new THREE.CylinderGeometry(cw * 0.45, cw * 0.45, ch * 0.8, 16);
        // Tilt slightly toward camera so the top ellipse is visible (classic DB icon)
        chamberGeo.rotateX(0.35);
    } else {
        const shape = new THREE.Shape();
        const w = cw / 2;
        const h = ch / 2;
        const r = 0.4;
        shape.moveTo(-w + r, -h);
        shape.lineTo(w - r, -h);
        shape.quadraticCurveTo(w, -h, w, -h + r);
        shape.lineTo(w, h - r);
        shape.quadraticCurveTo(w, h, w - r, h);
        shape.lineTo(-w + r, h);
        shape.quadraticCurveTo(-w, h, -w, h - r);
        shape.lineTo(-w, -h + r);
        shape.quadraticCurveTo(-w, -h, -w + r, -h);
        const extrudeSettings = { depth: cd, bevelEnabled: true, bevelThickness: 0.15, bevelSize: 0.15, bevelSegments: 3 };
        chamberGeo = new THREE.ExtrudeGeometry(shape, extrudeSettings);
        chamberGeo.translate(0, 0, -cd / 2);
    }

    const chamberMat = new THREE.MeshPhysicalMaterial({
        color: color,
        roughness: 0.8,
        metalness: 0.05,
        transparent: true,
        opacity: 0.75,
        side: THREE.DoubleSide,
    });
    const mesh = new THREE.Mesh(chamberGeo, chamberMat);
    mesh.castShadow = true;
    mesh.receiveShadow = true;
    group.add(mesh);

    // Inner glow (point light inside chamber)
    const light = new THREE.PointLight(color, 0.4 + scale * 0.3, 3 + scale * 3);
    light.position.set(0, 0, 0);
    group.add(light);

    // Edge wireframe for definition
    const edges = new THREE.EdgesGeometry(chamberGeo, 20);
    const edgeMat = new THREE.LineBasicMaterial({ color: COLORS.chamberEdge, transparent: true, opacity: 0.4 });
    group.add(new THREE.LineSegments(edges, edgeMat));

    // Node label
    const label = createTextSprite(node.name, color);
    label.position.set(0, ch / 2 + 0.6, 0.5);
    label.scale.set(3.5 * scale, 1.2, 1);
    group.add(label);

    group.position.copy(position);
    return group;
}

// ── Text Sprite ─────────────────────────────────────────────────────
function createTextSprite(text, color = 0xffffff, fontSize = 0.7) {
    const canvas = document.createElement('canvas');
    const ctx = canvas.getContext('2d');
    canvas.width = 512;
    canvas.height = 128;

    const fontPx = Math.round(fontSize * 60);
    ctx.font = `bold ${fontPx}px 'Segoe UI', system-ui, sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';

    // Shadow
    ctx.shadowColor = 'rgba(0,0,0,0.7)';
    ctx.shadowBlur = 6;
    ctx.shadowOffsetX = 2;
    ctx.shadowOffsetY = 2;

    // Text
    const hex = '#' + new THREE.Color(color).getHexString();
    ctx.fillStyle = hex;
    ctx.fillText(text, 256, 64);

    const texture = new THREE.CanvasTexture(canvas);
    texture.minFilter = THREE.LinearFilter;

    const mat = new THREE.SpriteMaterial({ map: texture, transparent: true, depthTest: false });
    return new THREE.Sprite(mat);
}

// ── Tunnel Routing ──────────────────────────────────────────────────
function computeTunnelWaypoints(startPos, endPos, allPositions, startId, endId, skipIds) {
    const margin = CHAMBER_WIDTH * 0.9;
    const marginY = CHAMBER_HEIGHT * 0.8;
    const dx = endPos.x - startPos.x;
    const dy = endPos.y - startPos.y;
    const len = Math.sqrt(dx * dx + dy * dy);
    if (len < 0.01) return [startPos.clone(), endPos.clone()];

    const obstructions = [];
    for (const [id, pos] of Object.entries(allPositions)) {
        if (id === startId || id === endId) continue;
        if (skipIds && skipIds.has(id)) continue;
        const t = ((pos.x - startPos.x) * dx + (pos.y - startPos.y) * dy) / (len * len);
        if (t <= 0.05 || t >= 0.95) continue;
        const lineX = startPos.x + t * dx;
        const lineY = startPos.y + t * dy;
        if (Math.abs(pos.x - lineX) < margin && Math.abs(pos.y - lineY) < marginY) {
            obstructions.push({ pos, t, lineX });
        }
    }

    if (obstructions.length === 0) {
        const mid = new THREE.Vector3().addVectors(startPos, endPos).multiplyScalar(0.5);
        mid.y -= len * 0.15;
        return [startPos.clone(), mid, endPos.clone()];
    }

    obstructions.sort((a, b) => a.t - b.t);
    const points = [startPos.clone()];
    for (const obs of obstructions) {
        const dodgeDir = (obs.lineX >= obs.pos.x) ? 1 : -1;
        points.push(new THREE.Vector3(obs.pos.x + dodgeDir * margin, obs.pos.y, 0));
    }
    points.push(endPos.clone());
    return points;
}

// ── Tunnel Builder ──────────────────────────────────────────────────
function createTunnel(waypoints, relationship) {
    const group = new THREE.Group();

    const curve = new THREE.CatmullRomCurve3(waypoints);

    // Outer tunnel wall
    const tubeGeo = new THREE.TubeGeometry(curve, 32, TUNNEL_RADIUS, 12, false);
    const tubeMat = new THREE.MeshPhysicalMaterial({
        color: COLORS.tunnel,
        roughness: 0.9,
        metalness: 0.0,
        transparent: true,
        opacity: 0.6,
        side: THREE.DoubleSide,
    });
    const tube = new THREE.Mesh(tubeGeo, tubeMat);
    tube.castShadow = true;
    group.add(tube);

    // Inner tunnel highlight
    const innerGeo = new THREE.TubeGeometry(curve, 32, TUNNEL_RADIUS * 0.6, 8, false);
    const innerMat = new THREE.MeshBasicMaterial({
        color: COLORS.tunnelInner,
        transparent: true,
        opacity: 0.15,
    });
    group.add(new THREE.Mesh(innerGeo, innerMat));

    // Store curve for ant pathing
    group.userData = { curve, relationship };

    return group;
}

// ── Ant Builder ─────────────────────────────────────────────────────
function createAnt(color) {
    const group = new THREE.Group();
    const antMat = new THREE.MeshPhysicalMaterial({
        color: color,
        roughness: 0.3,
        metalness: 0.2,
    });

    // Body segments (head, thorax, abdomen)
    const headGeo = new THREE.SphereGeometry(0.08, 8, 6);
    const head = new THREE.Mesh(headGeo, antMat);
    head.position.set(0.18, 0, 0);
    group.add(head);

    const thoraxGeo = new THREE.SphereGeometry(0.1, 8, 6);
    thoraxGeo.scale(1.0, 0.8, 0.8);
    const thorax = new THREE.Mesh(thoraxGeo, antMat);
    group.add(thorax);

    const abdomenGeo = new THREE.SphereGeometry(0.13, 8, 6);
    abdomenGeo.scale(1.2, 0.9, 0.9);
    const abdomen = new THREE.Mesh(abdomenGeo, antMat);
    abdomen.position.set(-0.22, 0, 0);
    group.add(abdomen);

    // Legs (3 pairs)
    const legMat = new THREE.MeshBasicMaterial({ color: color });
    for (let side = -1; side <= 1; side += 2) {
        for (let i = -1; i <= 1; i++) {
            const legGeo = new THREE.CylinderGeometry(0.01, 0.01, 0.15, 4);
            const leg = new THREE.Mesh(legGeo, legMat);
            leg.position.set(i * 0.08, -0.06, side * 0.08);
            leg.rotation.z = side * 0.6;
            leg.rotation.x = i * 0.3;
            group.add(leg);
        }
    }

    // Antennae
    const antennaMat = new THREE.MeshBasicMaterial({ color: color });
    for (let side = -1; side <= 1; side += 2) {
        const antennaGeo = new THREE.CylinderGeometry(0.008, 0.005, 0.18, 4);
        const antenna = new THREE.Mesh(antennaGeo, antennaMat);
        antenna.position.set(0.24, 0.06, side * 0.04);
        antenna.rotation.z = 0.8;
        antenna.rotation.y = side * 0.5;
        group.add(antenna);
    }

    return group;
}

// ── Ant Animation State ─────────────────────────────────────────────
class AntAgent {
    constructor(mesh, curves, flowColor, speed) {
        this.mesh = mesh;
        this.curves = curves; // Array of { curve, reverse } for each transition
        this.flowColor = flowColor;
        this.speed = speed;
        this.currentSegment = 0;
        this.t = Math.random(); // Start at random position along path
        this.pausing = false;
        this.pauseTimer = 0;
        this.wobbleOffset = Math.random() * Math.PI * 2;
    }

    update(delta) {
        if (this.curves.length === 0) return;

        if (this.pausing) {
            this.pauseTimer -= delta;
            if (this.pauseTimer <= 0) {
                this.pausing = false;
                this.currentSegment = (this.currentSegment + 1) % this.curves.length;
                this.t = 0;
            }
            // Wiggle in place while pausing
            this.mesh.rotation.z = Math.sin(Date.now() * 0.01 + this.wobbleOffset) * 0.2;
            return;
        }

        const segment = this.curves[this.currentSegment];
        if (!segment) return;

        this.t += delta * this.speed / segment.curve.getLength();

        if (this.t >= 1) {
            // Reached end of segment — pause briefly at chamber
            this.t = 1;
            this.pausing = true;
            this.pauseTimer = 0.3 + Math.random() * 0.5;
        }

        const effectiveT = segment.reverse ? 1 - this.t : this.t;
        const pos = segment.curve.getPointAt(Math.max(0, Math.min(1, effectiveT)));
        this.mesh.position.copy(pos);

        // Orient ant along path
        const lookT = Math.max(0, Math.min(1, effectiveT + (segment.reverse ? -0.01 : 0.01)));
        const lookPos = segment.curve.getPointAt(Math.max(0, Math.min(1, lookT)));
        const dir = new THREE.Vector3().subVectors(lookPos, pos).normalize();
        if (dir.length() > 0.001) {
            const angle = Math.atan2(dir.y, dir.x);
            this.mesh.rotation.z = angle;
        }

        // Subtle bobbing
        this.mesh.position.y += Math.sin(Date.now() * 0.008 + this.wobbleOffset) * 0.02;
    }
}

// ── Build the Scene ─────────────────────────────────────────────────
const nodes = calmData.nodes || [];
const relationships = calmData.relationships || [];
const flows = calmData.flows || [];

// Layout
const { positions, containment } = computeLayout(nodes, relationships);

// Earth
scene.add(buildEarth());

// Container outlines (render first, behind chambers)
const containerGroup = new THREE.Group();
Object.entries(containment).forEach(([containerId, childIds]) => {
    const childPositions = childIds.filter(id => positions[id]).map(id => positions[id]);
    if (childPositions.length === 0) return;

    // Compute bounding box of children with padding
    const pad = 2.0;
    let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    childPositions.forEach(p => {
        minX = Math.min(minX, p.x);
        maxX = Math.max(maxX, p.x);
        minY = Math.min(minY, p.y);
        maxY = Math.max(maxY, p.y);
    });
    const w = (maxX - minX) + CHAMBER_WIDTH + pad * 2;
    const h = (maxY - minY) + CHAMBER_HEIGHT + pad * 2;
    const cx = (minX + maxX) / 2;
    const cy = (minY + maxY) / 2;

    // Rounded rectangle outline
    const shape = new THREE.Shape();
    const hw = w / 2, hh = h / 2, r = 0.8;
    shape.moveTo(-hw + r, -hh);
    shape.lineTo(hw - r, -hh);
    shape.quadraticCurveTo(hw, -hh, hw, -hh + r);
    shape.lineTo(hw, hh - r);
    shape.quadraticCurveTo(hw, hh, hw - r, hh);
    shape.lineTo(-hw + r, hh);
    shape.quadraticCurveTo(-hw, hh, -hw, hh - r);
    shape.lineTo(-hw, -hh + r);
    shape.quadraticCurveTo(-hw, -hh, -hw + r, -hh);

    // Dashed outline
    const points = shape.getPoints(48);
    const lineGeo = new THREE.BufferGeometry().setFromPoints(points);
    const lineMat = new THREE.LineDashedMaterial({
        color: 0xc4a97d,
        dashSize: 0.4,
        gapSize: 0.2,
        transparent: true,
        opacity: 0.6,
    });
    const outline = new THREE.Line(lineGeo, lineMat);
    outline.computeLineDistances();
    outline.position.set(cx, cy, 0.1);
    containerGroup.add(outline);

    // Transparent fill
    const fillGeo = new THREE.ShapeGeometry(shape);
    const fillMat = new THREE.MeshBasicMaterial({
        color: 0xd4a056,
        transparent: true,
        opacity: 0.08,
        side: THREE.DoubleSide,
    });
    const fill = new THREE.Mesh(fillGeo, fillMat);
    fill.position.set(cx, cy, -0.1);
    containerGroup.add(fill);

    // Container label
    const containerNode = nodes.find(n => n['unique-id'] === containerId);
    const containerName = containerNode ? containerNode.name : containerId;
    const label = createTextSprite(containerName, 0xc4a97d, 0.5);
    label.position.set(cx, cy + hh + 0.6, 0.5);
    label.scale.set(4, 1.2, 1);
    containerGroup.add(label);
});
scene.add(containerGroup);

// Compute flow participation per node (how many distinct flows touch each node)
const flowCounts = {};
flows.forEach(flow => {
    const nodesInFlow = new Set();
    (flow.transitions || []).forEach(t => {
        const rel = relationships.find(r => r['unique-id'] === t['relationship-unique-id']);
        if (!rel) return;
        const rt = rel['relationship-type'];
        if (rt.connects) {
            nodesInFlow.add(rt.connects.source.node);
            nodesInFlow.add(rt.connects.destination.node);
        }
        if (rt.interacts) {
            nodesInFlow.add(rt.interacts.actor);
            (rt.interacts.nodes || []).forEach(n => nodesInFlow.add(n));
        }
    });
    nodesInFlow.forEach(id => { flowCounts[id] = (flowCounts[id] || 0) + 1; });
});
const maxFlowCount = Math.max(1, ...Object.values(flowCounts));

// Chambers (skip pure containers that only exist to group others)
const containerIds = new Set(Object.keys(containment));
const chamberGroup = new THREE.Group();
nodes.forEach(node => {
    const pos = positions[node['unique-id']];
    if (pos && !containerIds.has(node['unique-id'])) {
        // Scale 1.0 (base) to 1.6 for the most-referenced node
        const fc = flowCounts[node['unique-id']] || 0;
        const scale = 1.0 + (fc / maxFlowCount) * 0.6;
        chamberGroup.add(createChamber(node, pos, scale));
    }
});
scene.add(chamberGroup);

// Build lookup for tunnels: relationship-id → { curve, source, destination }
const tunnelCurves = {};
const tunnelGroup = new THREE.Group();

relationships.forEach(rel => {
    const relType = rel['relationship-type'];
    if (relType.connects) {
        const srcId = relType.connects.source.node;
        const dstId = relType.connects.destination.node;
        const srcPos = positions[srcId];
        const dstPos = positions[dstId];
        if (srcPos && dstPos) {
            const wp = computeTunnelWaypoints(srcPos, dstPos, positions, srcId, dstId, containerIds);
            const tunnel = createTunnel(wp, rel);
            tunnelGroup.add(tunnel);
            tunnelCurves[rel['unique-id']] = {
                curve: tunnel.userData.curve,
                source: srcId,
                destination: dstId,
            };
        }
    }
    // Interacts relationships — thin connection at surface
    if (relType.interacts) {
        const actorId = relType.interacts.actor;
        const targetNodes = relType.interacts.nodes || [];
        targetNodes.forEach(targetId => {
            const srcPos = positions[actorId];
            const dstPos = positions[targetId];
            if (srcPos && dstPos) {
                const wp = computeTunnelWaypoints(srcPos, dstPos, positions, actorId, targetId, containerIds);
                const tunnel = createTunnel(wp, rel);
                tunnelGroup.add(tunnel);
                tunnelCurves[rel['unique-id']] = {
                    curve: tunnel.userData.curve,
                    source: actorId,
                    destination: targetId,
                };
            }
        });
    }
});
scene.add(tunnelGroup);

// ── Lighting ────────────────────────────────────────────────────────
const ambientLight = new THREE.AmbientLight(0xfff5e6, 0.4);
scene.add(ambientLight);

const sunLight = new THREE.DirectionalLight(0xfff5e6, 1.2);
sunLight.position.set(10, 30, 20);
sunLight.castShadow = true;
sunLight.shadow.mapSize.width = 2048;
sunLight.shadow.mapSize.height = 2048;
sunLight.shadow.camera.near = 0.1;
sunLight.shadow.camera.far = 100;
sunLight.shadow.camera.left = -40;
sunLight.shadow.camera.right = 40;
sunLight.shadow.camera.top = 40;
sunLight.shadow.camera.bottom = -40;
scene.add(sunLight);

// Underground ambient warmth
const warmLight = new THREE.PointLight(0xFFAA55, 0.3, 50);
warmLight.position.set(0, -10, 5);
scene.add(warmLight);

// ── Ants ────────────────────────────────────────────────────────────
// Each flow gets its own array of agents; all start disabled
const flowAgentGroups = []; // { agents: AntAgent[], enabled: false, flowIdx, color }

if (flows.length > 0) {
    flows.forEach((flow, flowIdx) => {
        const color = FLOW_COLORS[flowIdx % FLOW_COLORS.length];
        const transitions = (flow.transitions || [])
            .slice()
            .sort((a, b) => a['sequence-number'] - b['sequence-number']);

        // Build curve array for this flow
        const flowCurves = [];
        transitions.forEach(transition => {
            const tunnelData = tunnelCurves[transition['relationship-unique-id']];
            if (tunnelData) {
                const reverse = transition.direction === 'destination-to-source';
                flowCurves.push({ curve: tunnelData.curve, reverse });
            }
        });

        const agents = [];
        if (flowCurves.length > 0) {
            for (let i = 0; i < ANT_COUNT_PER_FLOW; i++) {
                const antMesh = createAnt(color);
                antMesh.visible = false; // Start hidden
                scene.add(antMesh);

                const speed = ANT_SPEED * (0.8 + Math.random() * 0.4);
                const agent = new AntAgent(antMesh, flowCurves, color, speed);
                agent.currentSegment = i % flowCurves.length;
                agent.t = (i / ANT_COUNT_PER_FLOW) * 0.8;
                agents.push(agent);
            }
        }

        flowAgentGroups.push({ agents, enabled: false, flowIdx, color });
    });
}

function setFlowEnabled(flowIdx, enabled) {
    const group = flowAgentGroups[flowIdx];
    if (!group) return;
    group.enabled = enabled;
    group.agents.forEach(agent => { agent.mesh.visible = enabled; });
}

// ── Flow Control Panel ──────────────────────────────────────────────
const flowListEl = document.getElementById('flow-list');
const flowSearchEl = document.getElementById('flow-search');
const flowToggleAllEl = document.getElementById('flow-toggle-all');
const flowCountEl = document.getElementById('flow-count');

const flowItems = []; // { el, checkbox, idx, name }

if (flowListEl && flows.length > 0) {
    flows.forEach((flow, idx) => {
        const color = FLOW_COLORS[idx % FLOW_COLORS.length];
        const hex = '#' + new THREE.Color(color).getHexString();

        const item = document.createElement('label');
        item.className = 'flow-item';

        const cb = document.createElement('input');
        cb.type = 'checkbox';
        cb.checked = false;
        cb.addEventListener('change', () => {
            setFlowEnabled(idx, cb.checked);
            updateFlowCount();
        });

        const swatch = document.createElement('span');
        swatch.className = 'flow-swatch';
        swatch.style.background = hex;

        const label = document.createElement('span');
        label.className = 'flow-label';
        label.textContent = flow.name;
        label.title = flow.description || flow.name;

        item.appendChild(cb);
        item.appendChild(swatch);
        item.appendChild(label);
        flowListEl.appendChild(item);

        flowItems.push({ el: item, checkbox: cb, idx, name: flow.name.toLowerCase() });
    });
}

function updateFlowCount() {
    if (!flowCountEl) return;
    const active = flowAgentGroups.filter(g => g.enabled).length;
    flowCountEl.textContent = active + ' / ' + flows.length + ' flows active';
}
updateFlowCount();

// Search filtering
if (flowSearchEl) {
    flowSearchEl.addEventListener('input', () => {
        const q = flowSearchEl.value.toLowerCase().trim();
        flowItems.forEach(fi => {
            fi.el.style.display = (!q || fi.name.includes(q)) ? '' : 'none';
        });
    });
}

// Toggle all button
if (flowToggleAllEl) {
    flowToggleAllEl.addEventListener('click', () => {
        const anyOff = flowAgentGroups.some(g => !g.enabled);
        flowItems.forEach(fi => {
            // Only toggle visible (non-filtered) items
            if (fi.el.style.display !== 'none') {
                fi.checkbox.checked = anyOff;
                setFlowEnabled(fi.idx, anyOff);
            }
        });
        flowToggleAllEl.textContent = anyOff ? 'Disable All' : 'Enable All';
        updateFlowCount();
    });
}

// ── HUD ─────────────────────────────────────────────────────────────
const titleEl = document.getElementById('title');
if (titleEl) {
    const archName = nodes.length > 0 ? 'Architecture Ant Farm' : 'Empty Ant Farm';
    titleEl.textContent = '🐜 ' + archName;
}

// ── Camera Positioning ──────────────────────────────────────────────
function fitCameraToScene() {
    const allPositions = Object.values(positions);
    if (allPositions.length === 0) {
        camera.position.set(0, -5, 25);
        controls.target.set(0, -5, 0);
        return;
    }

    const center = new THREE.Vector3();
    allPositions.forEach(p => center.add(p));
    center.divideScalar(allPositions.length);

    // Calculate bounding box for better framing
    let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
    allPositions.forEach(p => {
        minX = Math.min(minX, p.x);
        maxX = Math.max(maxX, p.x);
        minY = Math.min(minY, p.y);
        maxY = Math.max(maxY, p.y);
    });
    const spanX = maxX - minX + CHAMBER_WIDTH * 2;
    const spanY = maxY - minY + CHAMBER_HEIGHT * 2;
    const maxSpan = Math.max(spanX, spanY);

    // Position camera directly in front, looking straight at the scene (2D view)
    const distance = Math.max(maxSpan * 1.2, 18);
    camera.position.set(center.x, center.y, distance);
    controls.target.set(center.x, center.y, 0);
    controls.update();
}

fitCameraToScene();

// ── Decorations ─────────────────────────────────────────────────────
function addDecorations() {
}

addDecorations();

// ── Remove Loading ──────────────────────────────────────────────────
const loadingEl = document.getElementById('loading');
if (loadingEl) loadingEl.style.display = 'none';

// ── Animation Loop ──────────────────────────────────────────────────
const clock = new THREE.Clock();

function animate() {
    requestAnimationFrame(animate);
    const delta = Math.min(clock.getDelta(), 0.05); // Clamp to avoid huge jumps

    // Update ants (only enabled flows)
    flowAgentGroups.forEach(group => {
        if (!group.enabled) return;
        group.agents.forEach(agent => agent.update(delta));
    });

    controls.update();
    renderer.render(scene, camera);
}

animate();

// ── Resize Handler ──────────────────────────────────────────────────
window.addEventListener('resize', () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
});
