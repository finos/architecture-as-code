{
  "nodes": [
    {
      "unique-id": "customer",
      "node-type": "actor",
      "name": "Customer",
      "description": "End user browsing and purchasing products"
    },
    {
      "unique-id": "web-app",
      "node-type": "webclient",
      "name": "Web Application",
      "description": "React-based storefront SPA",
      "interfaces": [
        {
          "unique-id": "web-url",
          "type": "url",
          "value": "https://shop.example.com"
        }
      ]
    },
    {
      "unique-id": "api-gateway",
      "node-type": "network",
      "name": "API Gateway",
      "description": "Kong API gateway handling routing, rate limiting, and auth",
      "interfaces": [
        {
          "unique-id": "gateway-url",
          "type": "url",
          "value": "https://api.example.com"
        }
      ]
    },
    {
      "unique-id": "product-service",
      "node-type": "service",
      "name": "Product Service",
      "description": "Manages product catalog, search, and inventory",
      "interfaces": [
        {
          "unique-id": "product-api",
          "type": "url",
          "value": "https://api.example.com/v1/products"
        }
      ]
    },
    {
      "unique-id": "order-service",
      "node-type": "service",
      "name": "Order Service",
      "description": "Handles order placement, tracking, and fulfillment",
      "interfaces": [
        {
          "unique-id": "order-api",
          "type": "url",
          "value": "https://api.example.com/v1/orders"
        }
      ]
    },
    {
      "unique-id": "auth-service",
      "node-type": "service",
      "name": "Auth Service",
      "description": "User authentication and authorization via JWT",
      "interfaces": [
        {
          "unique-id": "auth-api",
          "type": "url",
          "value": "https://api.example.com/v1/auth"
        }
      ]
    },
    {
      "unique-id": "notification-service",
      "node-type": "service",
      "name": "Notification Service",
      "description": "Sends email and push notifications for order events"
    },
    {
      "unique-id": "product-db",
      "node-type": "database",
      "name": "Product Database",
      "description": "PostgreSQL storing product catalog and inventory",
      "interfaces": [
        {
          "unique-id": "product-db-port",
          "type": "host-port",
          "value": "product-db:5432"
        }
      ]
    },
    {
      "unique-id": "order-db",
      "node-type": "database",
      "name": "Order Database",
      "description": "PostgreSQL storing orders and transaction history",
      "interfaces": [
        {
          "unique-id": "order-db-port",
          "type": "host-port",
          "value": "order-db:5432"
        }
      ]
    },
    {
      "unique-id": "user-db",
      "node-type": "database",
      "name": "User Database",
      "description": "PostgreSQL storing user accounts and credentials",
      "interfaces": [
        {
          "unique-id": "user-db-port",
          "type": "host-port",
          "value": "user-db:5432"
        }
      ]
    },
    {
      "unique-id": "cache",
      "node-type": "database",
      "name": "Redis Cache",
      "description": "In-memory cache for sessions and product data",
      "interfaces": [
        {
          "unique-id": "cache-port",
          "type": "host-port",
          "value": "redis:6379"
        }
      ]
    },
    {
      "unique-id": "message-queue",
      "node-type": "data-asset",
      "name": "Message Queue",
      "description": "RabbitMQ for async event processing between services"
    },
    {
      "unique-id": "payment-gateway",
      "node-type": "system",
      "name": "Payment Gateway",
      "description": "External Stripe payment processing system"
    },
    {
      "unique-id": "cloud-platform",
      "node-type": "ecosystem",
      "name": "AWS Cloud",
      "description": "AWS cloud environment hosting all services"
    }
  ],
  "relationships": [
    {
      "unique-id": "customer-to-web",
      "description": "Customer browses and shops via web app",
      "relationship-type": {
        "interacts": {
          "actor": "customer",
          "nodes": [
            "web-app"
          ]
        }
      }
    },
    {
      "unique-id": "web-to-gateway",
      "protocol": "HTTPS",
      "description": "Web app sends API requests through gateway",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "web-app"
          },
          "destination": {
            "node": "api-gateway"
          }
        }
      }
    },
    {
      "unique-id": "gateway-to-products",
      "protocol": "HTTPS",
      "description": "Routes product requests to product service",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "api-gateway"
          },
          "destination": {
            "node": "product-service"
          }
        }
      }
    },
    {
      "unique-id": "gateway-to-orders",
      "protocol": "HTTPS",
      "description": "Routes order requests to order service",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "api-gateway"
          },
          "destination": {
            "node": "order-service"
          }
        }
      }
    },
    {
      "unique-id": "gateway-to-auth",
      "protocol": "HTTPS",
      "description": "Routes auth requests and validates tokens",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "api-gateway"
          },
          "destination": {
            "node": "auth-service"
          }
        }
      }
    },
    {
      "unique-id": "products-to-db",
      "protocol": "TCP",
      "description": "Product service reads/writes catalog data",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "product-service"
          },
          "destination": {
            "node": "product-db"
          }
        }
      }
    },
    {
      "unique-id": "products-to-cache",
      "protocol": "TCP",
      "description": "Caches frequently accessed product data",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "product-service"
          },
          "destination": {
            "node": "cache"
          }
        }
      }
    },
    {
      "unique-id": "orders-to-db",
      "protocol": "TCP",
      "description": "Order service persists order data",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "order-service"
          },
          "destination": {
            "node": "order-db"
          }
        }
      }
    },
    {
      "unique-id": "orders-to-payment",
      "protocol": "HTTPS",
      "description": "Processes payments via Stripe API",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "order-service"
          },
          "destination": {
            "node": "payment-gateway"
          }
        }
      }
    },
    {
      "unique-id": "orders-to-queue",
      "protocol": "AMQP",
      "description": "Publishes order events for async processing",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "order-service"
          },
          "destination": {
            "node": "message-queue"
          }
        }
      }
    },
    {
      "unique-id": "notifications-from-queue",
      "protocol": "AMQP",
      "description": "Notification service consumes order events",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "message-queue"
          },
          "destination": {
            "node": "notification-service"
          }
        }
      }
    },
    {
      "unique-id": "auth-to-db",
      "protocol": "TCP",
      "description": "Auth service verifies credentials and manages users",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "auth-service"
          },
          "destination": {
            "node": "user-db"
          }
        }
      }
    },
    {
      "unique-id": "auth-to-cache",
      "protocol": "TCP",
      "description": "Caches session tokens and auth state",
      "relationship-type": {
        "connects": {
          "source": {
            "node": "auth-service"
          },
          "destination": {
            "node": "cache"
          }
        }
      }
    },
    {
      "unique-id": "products-in-cloud",
      "description": "Product service deployed in AWS",
      "relationship-type": {
        "deployed-in": {
          "container": "cloud-platform",
          "nodes": [
            "product-service"
          ]
        }
      }
    },
    {
      "unique-id": "orders-in-cloud",
      "description": "Order service deployed in AWS",
      "relationship-type": {
        "deployed-in": {
          "container": "cloud-platform",
          "nodes": [
            "order-service"
          ]
        }
      }
    },
    {
      "unique-id": "auth-in-cloud",
      "description": "Auth service deployed in AWS",
      "relationship-type": {
        "deployed-in": {
          "container": "cloud-platform",
          "nodes": [
            "auth-service"
          ]
        }
      }
    },
    {
      "unique-id": "notifications-in-cloud",
      "description": "Notification service deployed in AWS",
      "relationship-type": {
        "deployed-in": {
          "container": "cloud-platform",
          "nodes": [
            "notification-service"
          ]
        }
      }
    }
  ]
}
