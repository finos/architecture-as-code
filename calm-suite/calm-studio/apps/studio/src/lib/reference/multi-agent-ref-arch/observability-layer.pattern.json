{
  "$schema": "https://calm.finos.org/release/1.2/meta/calm.json",
  "$id": "https://calm.finos.org/marefarch/observability-layer.pattern.json",
  "title": "Observability Layer Pattern",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 1,
      "allOf": [
        {
          "contains": {
            "properties": {
              "unique-id": {
                "const": "observability-layer"
              }
            },
            "required": [
              "unique-id"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "node-type": {
                "const": "ai:observability"
              }
            },
            "required": [
              "node-type"
            ]
          }
        },
        {
          "contains": {
            "properties": {
              "node-type": {
                "const": "service"
              }
            },
            "required": [
              "node-type"
            ]
          }
        }
      ]
    },
    "relationships": {
      "type": "array"
    }
  },
  "required": [
    "nodes",
    "relationships"
  ]
}
