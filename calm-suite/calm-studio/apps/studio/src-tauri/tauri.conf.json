{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CalmStudio",
  "version": "0.1.0",
  "identifier": "app.calmstudio.studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CalmStudio",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "externalBin": ["binaries/calmstudio-mcp"],
    "fileAssociations": [
      {
        "name": "CALM Architecture",
        "ext": ["calm.json", "json"],
        "mimeType": "application/json",
        "description": "CALM Architecture File",
        "role": "Editor"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_GENERATED_PUBKEY",
      "endpoints": [
        "https://github.com/opsflo/calmstudio/releases/latest/download/latest.json"
      ]
    },
    "deep-link": {
      "desktop": {
        "schemes": []
      }
    }
  }
}
